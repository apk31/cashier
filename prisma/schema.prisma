generator client {
  provider    = "prisma-client-js"
  engineType  = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
  // SPLIT is not a payment method — a split payment is represented
  // by multiple rows in the payments table (one per method used)
}

enum MemberTier {
  BASIC
  SILVER
  GOLD
}

enum VoucherType {
  PERCENTAGE
  FIXED
}

enum StockReason {
  SALE
  RESTOCK
  ADJUSTMENT
  DAMAGE
  RETURN
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String        @id @db.Uuid
  email        String?       @unique
  username     String?       @unique
  password     String?
  pin          String?
  name         String
  role         Role          @default(CASHIER)
  transactions Transaction[]
  price_logs   PriceLog[]
  stock_logs   StockLog[]
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@map("users")
}

model Category {
  id            String     @id @db.Uuid
  name          String
  parent_id     String?    @db.Uuid
  parent        Category?  @relation("SubCategories", fields: [parent_id], references: [id])
  subcategories Category[] @relation("SubCategories")
  products      Product[]

  @@index([parent_id])
  @@map("categories")
}

model Product {
  id          String    @id @db.Uuid
  name        String
  category_id String    @db.Uuid
  category    Category  @relation(fields: [category_id], references: [id])
  variants    Variant[]

  @@index([category_id])
  @@index([name])
  @@map("products")
}

model Variant {
  id             String            @id @db.Uuid
  product_id     String            @db.Uuid
  name           String?
  sku            String            @unique
  barcode        String?           @unique
  price          Decimal           @db.Decimal(12, 2)
  stock          Int               @default(0)
  has_open_price Boolean           @default(false)
  product        Product           @relation(fields: [product_id], references: [id])
  price_logs     PriceLog[]
  items          TransactionItem[]
  stock_logs     StockLog[]

  @@index([product_id])
  @@index([barcode])
  @@map("variants")
}

model PriceLog {
  id         String   @id @db.Uuid
  variant_id String   @db.Uuid
  old_price  Decimal  @db.Decimal(12, 2)
  new_price  Decimal  @db.Decimal(12, 2)
  changed_by String   @db.Uuid
  created_at DateTime @default(now())
  variant    Variant  @relation(fields: [variant_id], references: [id])
  user       User     @relation(fields: [changed_by], references: [id])

  @@index([variant_id])
  @@index([changed_by])
  @@map("price_logs")
}

model StockLog {
  id         String      @id @db.Uuid
  variant_id String      @db.Uuid
  user_id    String      @db.Uuid
  old_stock  Int
  new_stock  Int
  change     Int         // positive = stock added, negative = stock removed
  reason     StockReason
  note       String?
  created_at DateTime    @default(now())
  variant    Variant     @relation(fields: [variant_id], references: [id])
  user       User        @relation(fields: [user_id], references: [id])

  @@index([variant_id])
  @@index([user_id])
  @@index([created_at])
  @@map("stock_logs")
}

model Transaction {
  id             String            @id @db.Uuid
  user_id        String            @db.Uuid
  member_id      String?           @db.Uuid
  voucher_id     String?           @db.Uuid
  subtotal       Decimal           @db.Decimal(12, 2)
  discount_total Decimal           @default(0) @db.Decimal(12, 2)
  total          Decimal           @db.Decimal(12, 2)
  created_at     DateTime          @default(now())
  user           User              @relation(fields: [user_id], references: [id])
  member         Member?           @relation(fields: [member_id], references: [id])
  voucher        Voucher?          @relation(fields: [voucher_id], references: [id])
  items          TransactionItem[]
  payments       Payment[]

  @@index([user_id])
  @@index([member_id])
  @@index([created_at])
  @@map("transactions")
}

model TransactionItem {
  id             String      @id @db.Uuid
  transaction_id String      @db.Uuid
  variant_id     String      @db.Uuid
  qty            Int
  price          Decimal     @db.Decimal(12, 2)
  discount       Decimal     @default(0) @db.Decimal(12, 2)
  transaction    Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  variant        Variant     @relation(fields: [variant_id], references: [id])

  @@index([transaction_id])
  @@index([variant_id])
  @@map("transaction_items")
}

model Payment {
  id             String        @id @db.Uuid
  transaction_id String        @db.Uuid
  method         PaymentMethod
  amount         Decimal       @db.Decimal(12, 2)
  ref_no         String?
  transaction    Transaction   @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

  @@index([transaction_id])
  @@map("payments")
}

model OfflineQueue {
  id         String    @id @db.Uuid
  payload    Json
  synced_at  DateTime?
  error      String?
  created_at DateTime  @default(now())

  @@index([synced_at])
  @@map("offline_queue")
}

model Member {
  id           String        @id @db.Uuid
  phone        String        @unique
  name         String
  points       Int           @default(0)
  tier         MemberTier    @default(BASIC)
  transactions Transaction[]
  created_at   DateTime      @default(now())

  @@index([phone])
  @@map("members")
}

model Voucher {
  id           String        @id @db.Uuid
  code         String        @unique
  type         VoucherType
  value        Decimal       @db.Decimal(12, 2)
  max_uses     Int           @default(1)
  used_count   Int           @default(0)
  exp          DateTime
  transactions Transaction[]

  @@index([code])
  @@map("vouchers")
}

model Setting {
  id             String @id @default("GLOBAL")
  store_info     Json
  tax_config     Json
  printer_config Json

  @@map("settings")
}
