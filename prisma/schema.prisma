generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
  SPLIT
}

model User {
  id           String        @id @db.Uuid // Generate UUIDv7 in the app layer
  email        String?       @unique      // Optional for cashiers if they only use PIN
  password     String?                    // Hashed password for Admin/Manager
  pin          String?                    // Hashed 4-6 digit PIN for Cashier fast-login
  name         String
  role         Role          @default(CASHIER)
  transactions Transaction[]
  price_logs   PriceLog[]
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@map("users")
}

model Category {
  id            String     @id @db.Uuid
  name          String
  parent_id     String?    @db.Uuid
  parent        Category?  @relation("SubCategories", fields: [parent_id], references: [id])
  subcategories Category[] @relation("SubCategories")
  products      Product[]

  @@map("categories")
}

model Product {
  id          String    @id @db.Uuid
  name        String
  category_id String    @db.Uuid
  category    Category  @relation(fields: [category_id], references: [id])
  variants    Variant[]

  @@map("products")
}

model Variant {
  id         String              @id @db.Uuid
  product_id String              @db.Uuid
  sku        String              @unique
  barcode    String?             @unique
  price      Decimal             @db.Decimal(12, 2)
  stock      Int                 @default(0)
  product    Product             @relation(fields: [product_id], references: [id])
  price_logs PriceLog[]
  items      TransactionItem[]

  @@map("variants")
}

model PriceLog {
  id         String   @id @db.Uuid
  variant_id String   @db.Uuid
  old_price  Decimal  @db.Decimal(12, 2)
  new_price  Decimal  @db.Decimal(12, 2)
  changed_by String   @db.Uuid
  created_at DateTime @default(now())
  variant    Variant  @relation(fields: [variant_id], references: [id])
  user       User     @relation(fields: [changed_by], references: [id])

  @@map("price_logs")
}

model Transaction {
  id         String              @id @db.Uuid // Matches the offline-generated UUIDv7
  user_id    String              @db.Uuid
  total      Decimal             @db.Decimal(12, 2)
  created_at DateTime            @default(now()) // Can be overwritten by offline timestamp
  user       User                @relation(fields: [user_id], references: [id])
  items      TransactionItem[]
  payments   Payment[]

  @@map("transactions")
}

model TransactionItem {
  id             String      @id @db.Uuid
  transaction_id String      @db.Uuid
  variant_id     String      @db.Uuid
  qty            Int
  price          Decimal     @db.Decimal(12, 2)
  discount       Decimal     @default(0) @db.Decimal(12, 2)
  transaction    Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  variant        Variant     @relation(fields: [variant_id], references: [id])

  @@map("transaction_items")
}

model Payment {
  id             String        @id @db.Uuid
  transaction_id String        @db.Uuid
  method         PaymentMethod
  amount         Decimal       @db.Decimal(12, 2)
  ref_no         String?       // For QRIS or Transfer reference
  transaction    Transaction   @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

model OfflineQueue {
  id        String    @id @db.Uuid // Corresponds to the offline transaction ID
  payload   Json      // The full offline transaction dump
  synced_at DateTime?
  error     String?

  @@map("offline_queue")
}

model Member {
  id     String @id @db.Uuid
  phone  String @unique
  name   String
  points Int    @default(0)
  tier   String @default("BASIC")

  @@map("members")
}

model Voucher {
  id    String   @id @db.Uuid
  code  String   @unique
  type  String   // e.g., "PERCENTAGE", "FIXED"
  value Decimal  @db.Decimal(12, 2)
  exp   DateTime

  @@map("vouchers")
}

model Setting {
  id             String @id @default("GLOBAL") // Singleton row
  store_info     Json
  tax_config     Json   // PKP toggle, NPWP, PPN %
  printer_config Json   // USB/BT/IP, paper width

  @@map("settings")
}